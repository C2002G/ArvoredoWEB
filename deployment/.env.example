# Arvoredo PDV - Variaveis de Ambiente
# Copie este arquivo para .env e preencha com suas configuracoes

# ============================================
# CONFIGURACAO DO BANCO DE DADOS
# ============================================

# String de conexao com PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/nomedobanco
DATABASE_URL=postgresql://postgres:SUA_SENHA_AQUI@localhost:5432/arvoredo

# ============================================
# CONFIGURACAO DA API
# ============================================

# Porta do servidor API (padrao: 8080)
PORT=8080

# Nivel de log (debug, info, warn, error)
LOG_LEVEL=info

# Ambiente (development, production)
NODE_ENV=development

# ============================================
# CONFIGURACAO DO FRONTEND
# ============================================

# Porta do servidor frontend (padrao: 5173)
# PORT=5173

# URL da API para conexao (padrao: http://localhost:8080)
# API_PROXY_TARGET=http://localhost:8080

# Caminho base (padrao: /)
# BASE_PATH=/

# ============================================
# INSTRUCOES DE USO
# ============================================

# 1. Copie este arquivo para .env
# 2. Substitua SUA_SENHA_AQUI pela senha do PostgreSQL
# 3. Os scripts ja estao configurados para usar DATABASE_URL
