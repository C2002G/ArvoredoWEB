DATABASE_URL=postgresql://postgres:1234@localhost:5432/arvoredo
PORT=8080

# Nome da impressora (ou aliases separados por ; , |). Ex:
# PRINTER_NAME=ELGIN i7(USB);ELGIN I7 PLUS;Elgin i9
PRINTER_NAME=ELGIN i7(USB)
# (Opcional) Só se o cupom sair muito estreito/largo: força -Width no Out-Printer (caracteres).
# Se vazio, o sistema não passa -Width (usa a área padrão do driver, recomendado).
# PRINTER_LINE_WIDTH=48
