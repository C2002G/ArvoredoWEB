<file path="deployment/SQL/2026-04-24-add-categoria-feira.sql">
DO $$
BEGIN
  IF NOT EXISTS (
    SELECT 1
    FROM pg_enum e
    JOIN pg_type t ON t.oid = e.enumtypid
    WHERE t.typname = 'categoria' AND e.enumlabel = 'feira'
  ) THEN
    ALTER TYPE categoria ADD VALUE 'feira';
  END IF;
END
$$;
</file>

