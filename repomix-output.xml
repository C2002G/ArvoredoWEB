    });
    setModalOpen(true);
  };

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    const payload = {
      nome: formData.nome,
      marca: formData.marca || null,
      codigo: formData.codigo || null,
      categoria: formData.categoria,
